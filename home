<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Secure Loan Request | Official Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
        .oswald { font-family: 'Oswald', sans-serif; }
        .pulse-bg { animation: pulseBg 2s infinite; }
        @keyframes pulseBg { 0% { background-color: #22c55e; } 50% { background-color: #16a34a; } 100% { background-color: #22c55e; } }
        .blur-in { animation: blurIn 0.5s ease-out forwards; }
        @keyframes blurIn { from { filter: blur(10px); opacity: 0; } to { filter: blur(0); opacity: 1; } }
    </style>
</head>
<body class="pb-10">

    <!-- Header (Элемент доверия) -->
    <header class="bg-[#111827] text-white p-4 shadow-lg sticky top-0 z-40 flex justify-between items-center border-b-[3px] border-green-500">
        <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
            <h1 class="text-xl font-black oswald tracking-wide uppercase">Secure Request</h1>
        </div>
        <div class="bg-green-500 text-black text-[10px] font-black uppercase px-2 py-1 rounded">256-bit SSL</div>
    </header>

    <!-- Индикатор прогресса -->
    <div id="progress-container" class="w-full bg-gray-300 h-2 shadow-inner">
        <div id="progress-bar" class="bg-green-500 h-2 w-[20%] transition-all duration-500 pulse-bg relative"></div>
    </div>

    <main class="p-4 max-w-md mx-auto relative min-h-[500px]">
        
        <!-- ШАГ 1: ВЫБОР СУММЫ -->
        <div id="step-1" class="funnel-step text-center mt-4 blur-in">
            <h2 class="text-3xl font-black text-gray-900 mb-1 oswald uppercase">How much?</h2>
            <p class="text-sm text-gray-600 font-bold mb-6 italic tracking-tight">Lock in your pre-approval in seconds.</p>
            <div class="grid grid-cols-2 gap-4">
                <button onclick="nextStep(2)" class="bg-white border-2 border-gray-300 rounded-2xl p-4 text-lg font-black text-gray-800 shadow-md active:scale-95 transition">$0 - $500</button>
                <button onclick="nextStep(2)" class="bg-white border-2 border-gray-300 rounded-2xl p-4 text-lg font-black text-gray-800 shadow-md active:scale-95 transition">$501 - $1,000</button>
                <button onclick="nextStep(2)" class="bg-white border-2 border-gray-300 rounded-2xl p-4 text-lg font-black text-gray-800 shadow-md active:scale-95 transition">$1,001 - $2,500</button>
                <button onclick="nextStep(2)" class="bg-white border-2 border-gray-300 rounded-2xl p-4 text-lg font-black text-gray-800 shadow-md active:scale-95 transition">$2,501 - $5,000+</button>
            </div>
            <div class="mt-8 bg-green-100 text-green-800 text-xs font-bold p-3 rounded-lg flex items-center justify-center gap-2 shadow-sm border border-green-200 uppercase">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                High Approval System Active
            </div>
        </div>

        <!-- ШАГ 2: ФИЛЬТР ПО ДОЛГАМ (15K ОФФЕР) -->
        <div id="step-2" class="funnel-step text-center mt-4 hidden">
            <h2 class="text-3xl font-black text-gray-900 mb-1 oswald uppercase tracking-tighter leading-none">Owe over $15,000?</h2>
            <p class="text-sm text-gray-600 font-bold mb-6">Total credit card or personal loan debt?</p>
            <div class="flex flex-col gap-4">
                <button onclick="checkDebt('yes')" class="bg-red-50 border-2 border-red-500 rounded-xl p-6 text-xl font-black text-red-700 shadow-md flex justify-between items-center active:scale-95 transition">
                    <span>⚠️ YES, OVER $15,000</span> <span class="text-red-600">➔</span>
                </button>
                <button onclick="checkDebt('no')" class="bg-white border-2 border-gray-300 rounded-xl p-6 text-xl font-black text-gray-800 shadow-sm flex justify-between items-center active:scale-95 transition">
                    <span>NO, UNDER $15,000</span> <span class="text-green-500">➔</span>
                </button>
            </div>
        </div>

        <!-- ШАГ 2.5: ОФФЕР CLIQSILVER (ИНТЕРСТИТИАЛ) -->
        <div id="step-debt-offer" class="funnel-step text-center mt-2 hidden">
            <div class="bg-red-600 rounded-t-2xl p-4 text-white shadow-lg"><h2 class="text-2xl font-black oswald uppercase text-white">⚠️ RELIEF ELIGIBLE</h2></div>
            <div class="bg-white border-x-4 border-b-4 border-red-600 rounded-b-2xl p-6 shadow-2xl text-center">
                <p class="text-gray-900 font-bold mb-5 text-lg leading-tight">Your $15K+ debt qualifies for the <span class="text-red-600 italic">2026 Settlement Program</span>. Stop borrowing and start settling.</p>
                <a href="https://offers.cliqsilver.com/debt" target="_blank" class="block w-full bg-red-600 text-white text-center text-2xl font-black oswald tracking-wide py-5 rounded-xl shadow-lg active:scale-95 transition animate-pulse uppercase">GET $15K+ RELIEF</a>
                <button onclick="nextStep(3)" class="mt-6 text-gray-400 font-bold text-xs underline uppercase tracking-widest">I still need a cash loan</button>
            </div>
        </div>

        <!-- ШАГ 3: ВЫБОР СКОРОСТИ -->
        <div id="step-3" class="funnel-step text-center mt-4 hidden">
            <h2 class="text-3xl font-black text-gray-900 mb-1 oswald uppercase leading-none mb-2">How fast?</h2>
            <p class="text-sm text-green-600 font-black mb-6 uppercase tracking-widest">FUNDS RESERVED FOR DISBURSEMENT</p>
            <div class="flex flex-col gap-3">
                <button onclick="nextStep(4)" class="bg-green-50 border-2 border-green-500 rounded-xl p-5 text-xl font-black text-gray-800 shadow-md flex justify-between items-center active:scale-95 transition"><span>⚡ ASAP (Today)</span> <span class="text-green-600">➔</span></button>
                <button onclick="nextStep(4)" class="bg-white border-2 border-gray-300 rounded-xl p-5 text-xl font-black text-gray-800 shadow-sm flex justify-between items-center active:scale-95 transition"><span>📅 Tomorrow</span> <span class="text-green-500">➔</span></button>
            </div>
        </div>

        <!-- ШАГ 4: КУДА ОТПРАВИТЬ -->
        <div id="step-4" class="funnel-step text-center mt-4 hidden">
            <h2 class="text-3xl font-black text-gray-900 mb-1 oswald uppercase">Send funds to?</h2>
            <p class="text-sm text-gray-600 font-bold mb-6 italic tracking-tight">Secure 256-bit encrypted transfer.</p>
            <div class="flex flex-col gap-3">
                <button onclick="nextStep(5)" class="bg-white border-2 border-gray-300 rounded-xl p-5 text-xl font-black text-gray-800 shadow-sm flex justify-between items-center active:scale-95 transition"><span>🏦 Direct Bank Deposit</span> <span class="text-green-500">➔</span></button>
                <button onclick="nextStep(5)" class="bg-white border-2 border-gray-300 rounded-xl p-5 text-xl font-black text-gray-800 shadow-sm flex justify-between items-center active:scale-95 transition"><span>💳 Debit Card</span> <span class="text-green-500">➔</span></button>
            </div>
        </div>

        <!-- ШАГ 5: ЭКРАН ЗАГРУЗКИ (ПРОГРЕВ) -->
        <div id="step-loading" class="funnel-step text-center mt-12 hidden">
            <div class="animate-spin rounded-full h-20 w-20 border-t-8 border-green-500 mx-auto mb-6"></div>
            <h2 class="text-2xl font-black text-gray-900 oswald uppercase">System Analysis...</h2>
            <p id="loading-status" class="text-lg text-green-600 font-bold mt-2">Connecting to lenders...</p>
        </div>

        <!-- ШАГ 6: ФИНАЛЬНАЯ ФОРМА (PROFITNER) -->
        <div id="step-form" class="funnel-step hidden">
            <div class="bg-green-600 text-white font-black p-4 rounded-xl mb-6 text-center shadow-lg uppercase tracking-wider">🔥 MATCH FOUND! COMPLETE FORM</div>
            <div class="bg-white rounded-2xl shadow-2xl border-2 border-gray-200 p-0 overflow-hidden min-h-[600px] w-full">
                <!-- PROFITNER FORM RUN -->
                <script src="https://cdn101.profitner.com/form/run.php?p=4F6456943C7B47CCAC2C8E76524813A6"></script>
            </div>
        </div>

        <!-- БЛОК ОТЗЫВОВ (СОЦ. ДОКАЗАТЕЛЬСТВО) -->
        <section id="reviews" class="mt-12 pt-8 border-t border-gray-300">
            <h3 class="oswald text-xl font-black uppercase text-gray-800 mb-6 text-center tracking-widest">Verified User Success</h3>
            <div class="space-y-4">
                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-200">
                    <div class="flex items-center gap-1 text-yellow-500 mb-2 text-sm">★★★★★</div>
                    <p class="text-xs text-gray-700 leading-relaxed italic font-medium">"I was skeptical but the process was so simple. Got my $1,000 deposit the same day. Saved my rent!"</p>
                    <div class="mt-3 flex items-center gap-2">
                        <div class="w-6 h-6 bg-gray-200 rounded-full flex items-center justify-center text-[10px] font-bold text-gray-500">M</div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-tighter">Mike R. — Austin, TX</span>
                    </div>
                </div>
                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-200">
                    <div class="flex items-center gap-1 text-yellow-500 mb-2 text-sm">★★★★★</div>
                    <p class="text-xs text-gray-700 leading-relaxed italic font-medium">"The debt relief option actually helped me more than the loan. Finally seeing a way out of my credit card debt."</p>
                    <div class="mt-3 flex items-center gap-2">
                        <div class="w-6 h-6 bg-gray-200 rounded-full flex items-center justify-center text-[10px] font-bold text-gray-500">S</div>
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-tighter">Sarah J. — Miami, FL</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- БЛОК FAQ (ДЛЯ МОДЕРАЦИИ) -->
        <section id="faq" class="mt-12 pt-8 border-t border-gray-300">
            <h3 class="oswald text-lg font-black uppercase text-gray-800 mb-4 px-2">Frequently Asked Questions</h3>
            <div class="space-y-3">
                <div class="p-3 bg-gray-50 rounded-lg">
                    <h4 class="text-xs font-black text-gray-900 mb-1 italic">How long does approval take?</h4>
                    <p class="text-[10px] text-gray-600">Most users receive a decision within 2-5 minutes after completing the full request form.</p>
                </div>
                <div class="p-3 bg-gray-50 rounded-lg">
                    <h4 class="text-xs font-black text-gray-900 mb-1 italic">Will this affect my credit score?</h4>
                    <p class="text-[10px] text-gray-600">Our initial matching process uses a soft pull which does not impact your credit score. Lenders may perform additional checks.</p>
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER (ЮРИДИЧЕСКАЯ ИНФОРМАЦИЯ ДЛЯ МОДЕРАЦИИ) -->
    <footer class="mt-10 bg-gray-200 p-8 text-gray-500 text-[10px] leading-relaxed border-t border-gray-300">
        <div class="max-w-md mx-auto">
            <p class="font-black mb-3 uppercase tracking-[0.2em] text-gray-400 border-b border-gray-300 pb-2 text-center">Important Legal Disclosures</p>
            <p class="mb-4 text-justify">
                <strong>Borrow Money Payday Online</strong> acts as a matching service and is NOT a lender. We do not make credit decisions. Our platform connects consumers with independent, third-party lenders who may be able to provide loans. We do not charge fees for this matching service. Not all lenders can provide the maximum amount requested, and approval is never guaranteed. 
            </p>
            <p class="mb-4 text-justify italic">
                <strong>Debt Relief Notice:</strong> Debt settlement and relief options are provided by independent financial partners. Results are not guaranteed and depend on your specific financial situation. Programs may impact your credit score and result in legal or tax consequences. Please consult with a professional financial advisor.
            </p>
            <div class="grid grid-cols-2 gap-2 text-center uppercase font-bold py-4 border-y border-gray-300 my-4">
                <span class="hover:text-gray-800 cursor-pointer">Privacy Policy</span>
                <span class="hover:text-gray-800 cursor-pointer">Terms of Service</span>
                <span class="hover:text-gray-800 cursor-pointer">Ad Disclosure</span>
                <span class="hover:text-gray-800 cursor-pointer">Contact Support</span>
            </div>
            <p class="mt-4 text-center text-gray-400 font-medium">© 2026 Secure Loan Network System. All rights reserved.<br>256-bit Bank-Level Encryption Verified.</p>
        </div>
    </footer>

    <script>
        function nextStep(step) {
            document.querySelectorAll('.funnel-step').forEach(el => el.classList.add('hidden'));
            if (step === 5) {
                document.getElementById('step-loading').classList.remove('hidden');
                document.getElementById('progress-bar').style.width = '90%';
                let i = 0; 
                const s = ["Securing funds...", "Bypassing FICO...", "Matching lenders...", "SUCCESS!"];
                const interval = setInterval(() => { 
                    if (i < s.length) {
                        document.getElementById('loading-status').innerText = s[i++];
                    } else { 
                        clearInterval(interval); 
                        showFinal(); 
                    } 
                }, 1000);
            } else {
                document.getElementById('step-' + step).classList.remove('hidden');
                document.getElementById('progress-bar').style.width = ((step-1)*25)+'%';
            }
        }
        function checkDebt(a) {
            if (a === 'yes') { 
                document.querySelectorAll('.funnel-step').forEach(el => el.classList.add('hidden'));
                document.getElementById('step-debt-offer').classList.remove('hidden'); 
                document.getElementById('progress-bar').style.width = '40%'; 
            } else {
                nextStep(3);
            }
        }
        function showFinal() {
            document.querySelectorAll('.funnel-step').forEach(el => el.classList.add('hidden'));
            document.getElementById('step-form').classList.remove('hidden');
            document.getElementById('progress-bar').style.width = '100%';
            setTimeout(() => document.getElementById('progress-container').classList.add('hidden'), 1000);
            // Прокрутка к форме для удобства
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>
